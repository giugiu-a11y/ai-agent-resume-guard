{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Agent Resume Guard Session Manifest",
  "type": "object",
  "required": ["sessions"],
  "properties": {
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["session_id"],
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "parent_session_id": {
            "type": ["string", "null"]
          },
          "source": {
            "type": "string"
          },
          "started_at": {
            "type": ["string", "number", "null"]
          },
          "last_activity_at": {
            "type": ["string", "number", "null"]
          },
          "title": {
            "type": "string"
          },
          "preview": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
